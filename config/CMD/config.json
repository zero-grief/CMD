// CMD unified config file
// Modules:
// - general      : core runtime settings
// - build        : startup/build/rebuild behavior
// - packhandling : scan sources, world resources.zip, extra definition targets
// - chat         : category and subgroup structure used by /cmd list and filters
// - preview      : representative vanilla items used in show_item previews
// - commands     : permission rules for admin commands

{
  "general": {
    "listPageSize": 8
  },
  "build": {
    "startupBuildEnabled": true,
    "reloadTriggersRebuild": true,
    "requireConfirmAfterFirstBuild": true,
    "startupBuildCompleted": false
  },
  "packhandling": {
    "enabled": true,
    "includeWorldResourcesZip": true,
    "includeDatapackZips": true,
    "includeModJars": false,
    "scanSources": [
      "resourcepacks",
      "world/datapacks",
      "config/CMD/packs",
      "serverfolder/customfoldername"
    ],
    "extraDefinitionTargets": [
      "minecraft:stick",
      "minecraft:paper"
    ]
  },
  "chat": {
    "categories": {
      "Equipment": {
        "subgroups": {
          "Helmets": ["leather_helmet", "chainmail_helmet", "iron_helmet", "golden_helmet", "diamond_helmet", "netherite_helmet", "turtle_helmet"],
          "Chestplates": ["leather_chestplate", "chainmail_chestplate", "iron_chestplate", "golden_chestplate", "diamond_chestplate", "netherite_chestplate"],
          "Leggings": ["leather_leggings", "chainmail_leggings", "iron_leggings", "golden_leggings", "diamond_leggings", "netherite_leggings"],
          "Boots": ["leather_boots", "chainmail_boots", "iron_boots", "golden_boots", "diamond_boots", "netherite_boots"],
          "Elytra": ["elytra"],
          "Shields": ["shield"]
        }
      },
      "Weapons": {
        "subgroups": {
          "Swords": ["wooden_sword", "stone_sword", "iron_sword", "golden_sword", "diamond_sword", "netherite_sword"],
          "Bows": ["bow"],
          "Crossbows": ["crossbow"],
          "Spears": ["trident"],
          "Maces": ["mace"]
        }
      },
      "Tools": {
        "subgroups": {
          "Pickaxes": ["wooden_pickaxe", "stone_pickaxe", "iron_pickaxe", "golden_pickaxe", "diamond_pickaxe", "netherite_pickaxe"],
          "Axes": ["wooden_axe", "stone_axe", "iron_axe", "golden_axe", "diamond_axe", "netherite_axe"],
          "Shovels": ["wooden_shovel", "stone_shovel", "iron_shovel", "golden_shovel", "diamond_shovel", "netherite_shovel"],
          "Hoes": ["wooden_hoe", "stone_hoe", "iron_hoe", "golden_hoe", "diamond_hoe", "netherite_hoe"],
          "Utility": ["fishing_rod", "shears", "flint_and_steel", "brush", "carrot_on_a_stick", "warped_fungus_on_a_stick"]
        }
      },
      "Special": {
        "subgroups": {
          "Totems": ["totem_of_undying"]
        }
      },
      "Cosmetic": {
        "subgroups": {
          "Headwear": ["carved_pumpkin"]
        }
      }
    }
  },
  "preview": {
    "enabled": true,
    "categoryItems": {
      "Equipment": "diamond_helmet",
      "Weapons": "diamond_sword",
      "Tools": "diamond_pickaxe",
      "Special": "elytra",
      "Cosmetic": "carved_pumpkin"
    },
    "subgroupItems": {
      "Helmets": "diamond_helmet",
      "Chestplates": "diamond_chestplate",
      "Leggings": "diamond_leggings",
      "Boots": "diamond_boots",
      "Elytra": "elytra",
      "Shields": "shield",
      "Headwear": "carved_pumpkin",
      "Swords": "diamond_sword",
      "Bows": "bow",
      "Crossbows": "crossbow",
      "Spears": "trident",
      "Maces": "mace",
      "Pickaxes": "diamond_pickaxe",
      "Axes": "diamond_axe",
      "Shovels": "diamond_shovel",
      "Hoes": "diamond_hoe",
      "Utility": "fishing_rod",
      "Totems": "totem_of_undying"
    }
  },
  "commands": {
    "apply": {
      "requiresOp4": true,
      "usePermissionNode": false,
      "permissionNode": "cmd.command.apply"
    },
    "reset": {
      "requiresOp4": true,
      "usePermissionNode": false,
      "permissionNode": "cmd.command.reset"
    },
    "reload": {
      "requiresOp4": true,
      "usePermissionNode": false,
      "permissionNode": "cmd.command.reload"
    },
    "rebuild": {
      "requiresOp4": true,
      "usePermissionNode": false,
      "permissionNode": "cmd.command.rebuild"
    }
  }
}
